# Aurora PostgreSQL (metadata repository + target warehouse)
AURORA_HOST=localhost
AURORA_PORT=5432
AURORA_DB=fab_ops
AURORA_USER=postgres
AURORA_PASSWORD=postgres
AURORA_METADATA_SCHEMA=metadata
AURORA_SSLMODE=prefer

# AWS
AWS_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:4566   # uncomment for LocalStack

# AI Agents
AGENTS_ENABLED=true
AGENT_MODEL_PROVIDER=anthropic
AGENT_MODEL_NAME=claude-sonnet-5
ANTHROPIC_API_KEY=

# Pipeline behavior
MAX_BATCH_RETRIES=3
SELF_HEALING_ENABLED=true
LOG_LEVEL=INFO
